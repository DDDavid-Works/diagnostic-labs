<Window x:Class="DiagnosticLabs.LabResultsWindows.UrinalysisWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DiagnosticLabs.LabResultsWindows"
        xmlns:menu="clr-namespace:DiagnosticLabs.UserControls"
        mc:Ignorable="d"
        Title="Urinalysis" Width="750" ShowInTaskbar="False"
        SizeToContent="Height" ResizeMode="NoResize" WindowStartupLocation="CenterScreen" Background="#dfecdf" Loaded="Window_Loaded">
    <StackPanel Orientation="Vertical">
        <menu:MessagesUserControl></menu:MessagesUserControl>
        <menu:ActionToolbarUserControl x:Name="ActionToolbar" NewCommand="{Binding NewCommand}" SaveCommand="{Binding SaveCommand}" DeleteCommand="{Binding DeleteCommand}" 
                                       SearchCommand="ActionToolbar_SearchCommand" PrintCommand="ActionToolbar_PrintCommand"
                                       SetDefaultsCommand="ActionToolbar_SetDefaultsCommand" SaveDefaultsCommand="ActionToolbar_SaveDefaultsCommand" CloseDefaultsCommand="ActionToolbar_CloseDefaultsCommand"></menu:ActionToolbarUserControl>
        <Grid Margin="0" VerticalAlignment="Top" Background="#ffffcc">
            <Grid.Resources>
                <Style TargetType="Label">
                    <Setter Property="Margin" Value="5" />
                    <Setter Property="Padding" Value="0,0,0,0" />
                    <Setter Property="HorizontalAlignment" Value="Right" />
                    <Setter Property="FontSize" Value="14" />
                </Style>
                <Style TargetType="TextBox">
                    <Setter Property="Margin" Value="0" />
                    <Setter Property="Height" Value="22" />
                    <Setter Property="Width" Value="90" />
                    <Setter Property="FontSize" Value="14"  />
                    <Setter Property="HorizontalContentAlignment" Value="Right" />
                </Style>
                <Style TargetType="Border">
                    <Setter Property="BorderBrush" Value="Black" />
                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                    <Setter Property="Margin" Value="0" />
                </Style>
            </Grid.Resources>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"></ColumnDefinition>
                <ColumnDefinition Width="120"></ColumnDefinition>
                <ColumnDefinition Width="100"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition></RowDefinition>
            </Grid.RowDefinitions>
            <Label Name="IdLabel" Content="Record Number:" Grid.Row="0" Grid.Column="1"></Label>
            <TextBox Name="IdTextBox" Grid.Row="0" Grid.Column="2" Text="{Binding Urinalysis.Id}" IsReadOnly="True" Margin="0,0,10,0"></TextBox>
            <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" />
        </Grid>
        <Grid Margin="10" VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="8*"></ColumnDefinition>
                <ColumnDefinition Width="2*"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition></RowDefinition>
                <RowDefinition></RowDefinition>
            </Grid.RowDefinitions>
            <Grid.Resources>
                <Style TargetType="Label">
                    <Setter Property="Margin" Value="5,5,0,5" />
                    <Setter Property="Padding" Value="0,2,0,0" />
                    <Setter Property="HorizontalAlignment" Value="Left" />
                    <Setter Property="FontSize" Value="14" />
                </Style>
                <Style TargetType="TextBox">
                    <Setter Property="Margin" Value="0,5,5,5" />
                    <Setter Property="Height" Value="22" />
                    <Setter Property="FontSize" Value="14" />
                </Style>
                <Style TargetType="DatePicker">
                    <Setter Property="VerticalContentAlignment" Value="Center" />
                    <Setter Property="Height" Value="22" />
                    <Setter Property="Margin" Value="0,5,5,5" />
                    <Setter Property="Padding" Value="0,0,0,0" />
                    <Setter Property="FontSize" Value="14" />
                </Style>
                <Style TargetType="Border">
                    <Setter Property="BorderBrush" Value="Black" />
                    <Setter Property="Margin" Value="0" />
                </Style>
            </Grid.Resources>
            <Grid Grid.Row="0" Grid.Column="0" VerticalAlignment="Top" Background="#efffef">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="11*"></ColumnDefinition>
                    <ColumnDefinition Width="15*"></ColumnDefinition>
                    <ColumnDefinition Width="1*"></ColumnDefinition>
                    <ColumnDefinition Width="6*"></ColumnDefinition>
                    <ColumnDefinition Width="15*"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                </Grid.RowDefinitions>
                <Border BorderThickness="1" Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" Grid.ColumnSpan="5" />
                <Label Name="PatientRegistrationCodeLabel" Content="Registration Code:" Grid.Row="0" Grid.Column="0"></Label>
                <menu:PatientRegistrationSearchByCodeUserControl Grid.Row="0" Grid.Column="1" Margin="0,5,5,0" x:Name="PatientRegistrationSearchByCode"></menu:PatientRegistrationSearchByCodeUserControl>
                <Label Name="InputRegDateLabel" Content="Registration Date:" Grid.Row="1" Grid.Column="0"></Label>
                <DatePicker Name="InputDateDatePicker" Grid.Row="1" Grid.Column="1" SelectedDate="{Binding PatientRegistration.InputDate}" IsEnabled="False"></DatePicker>
                <Label Name="CompanyNameLabel" Content="Company:" Grid.Row="0" Grid.Column="3"></Label>
                <TextBox Name="CompanyNameTextBox" Grid.Row="0" Grid.Column="4" Text="{Binding SelectedCompany.CompanyName}" IsReadOnly="True"></TextBox>
                <Label Name="BatchNameLabel" Content="Batch:" Grid.Row="1" Grid.Column="3"></Label>
                <TextBox Name="BatchNameTextBox" Grid.Row="1" Grid.Column="4" Text="{Binding SelectedBatchName}" IsReadOnly="True"></TextBox>
            </Grid>
            <Label Name="UrinalysisLabel" Content="URINALYSIS" Grid.Row="1" Grid.Column="0" FontSize="16" Margin="0,22,0,0"
                   FontWeight="SemiBold" Padding="0,5,5,5" BorderThickness="0,0,0,2" BorderBrush="Black" VerticalAlignment="Top" HorizontalAlignment="Stretch"></Label>

            <StackPanel Grid.Row="0" Grid.Column="1" Grid.RowSpan="2" Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0">
                <Border BorderThickness="2" BorderBrush="Black" Margin="0" Height="120" Width="120" Padding="2">
                    <Image Name="Photo" Source="{Binding LogoImageSource}"></Image>
                </Border>
            </StackPanel>
        </Grid>
        <Grid Margin="10,10,10,0" VerticalAlignment="Top">
            <Grid.Resources>
                <Style TargetType="Label">
                    <Setter Property="Margin" Value="0,0,0,5" />
                    <Setter Property="Padding" Value="0,2,0,0" />
                    <Setter Property="HorizontalAlignment" Value="Left" />
                    <Setter Property="FontSize" Value="14" />
                </Style>
                <Style TargetType="TextBox">
                    <Setter Property="Margin" Value="0,0,0,5" />
                    <Setter Property="Height" Value="22" />
                    <Setter Property="FontSize" Value="14" />
                </Style>
                <Style TargetType="ComboBox">
                    <Setter Property="VerticalContentAlignment" Value="Center" />
                    <Setter Property="Height" Value="22" />
                    <Setter Property="Padding" Value="2,0,0,0" />
                    <Setter Property="Margin" Value="0,0,0,5" />
                    <Setter Property="FontSize" Value="14" />
                    <Setter Property="IsEditable" Value="True" />
                    <Setter Property="IsTextSearchEnabled" Value="True" />
                </Style>
                <Style TargetType="DatePicker">
                    <Setter Property="VerticalContentAlignment" Value="Center" />
                    <Setter Property="Height" Value="22" />
                    <Setter Property="Margin" Value="0,0,0,5" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="FontSize" Value="14" />
                </Style>
            </Grid.Resources>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="10*"></ColumnDefinition>
                <ColumnDefinition Width="15*"></ColumnDefinition>
                <ColumnDefinition Width="2*"></ColumnDefinition>
                <ColumnDefinition Width="8*"></ColumnDefinition>
                <ColumnDefinition Width="8*"></ColumnDefinition>
                <ColumnDefinition Width="2*"></ColumnDefinition>
                <ColumnDefinition Width="3*"></ColumnDefinition>
                <ColumnDefinition Width="5*"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition></RowDefinition>
                <RowDefinition></RowDefinition>
                <RowDefinition></RowDefinition>
                <RowDefinition></RowDefinition>
            </Grid.RowDefinitions>
            <Label Name="PatientCodeLabel" Content="Patient Code:" Grid.Row="0" Grid.Column="0"></Label>
            <menu:PatientSearchByCodeUserControl Grid.Row="0" Grid.Column="1" x:Name="PatientSearchByCode"></menu:PatientSearchByCodeUserControl>
            <Label Name="PatientNameLabel" Content="Patient Name:" Grid.Row="1" Grid.Column="0"></Label>
            <menu:PatientSearchByNameUserControl Grid.Row="1" Grid.Column="1" x:Name="PatientSearchByName"></menu:PatientSearchByNameUserControl>
            <Label Name="CompanyOrPhysicianLabel" Content="Company/Physician:" Grid.Row="2" Grid.Column="0"></Label>
            <ComboBox Name="CompanyOrPhysicianTextBox" Grid.Row="2" Grid.Column="1" Text="" IsEditable="True" IsTextSearchEnabled="True" ItemsSource="{Binding CompanyOrPhysicians}" SelectedValue="{Binding Patient.CompanyName}"></ComboBox>
            <Label Name="AgeLabel" Content="Age:" Grid.Row="0" Grid.Column="3"></Label>
            <TextBox Name="AgeTextBox" Grid.Row="0" Grid.Column="4" Text="{Binding Patient.Age}"></TextBox>
            <Label Name="SexLabel" Content="Sex:" Grid.Row="0" Grid.Column="6"></Label>
            <ComboBox Name="SexTextBox" Grid.Row="0" Grid.Column="7" ItemsSource="{Binding Genders}" SelectedValue="{Binding Patient.Gender}"></ComboBox>
            <Label Name="DateRequestedLabel" Content="Date Requested:" Grid.Row="1" Grid.Column="3"></Label>
            <DatePicker Name="DateRequestedTextBox" Grid.Row="1" Grid.Column="4" SelectedDate="{Binding Urinalysis.DateRequested}"></DatePicker>
        </Grid>
        <Grid Margin="10,10,10,0" VerticalAlignment="Top">
            <Grid.Resources>
                <Style TargetType="Label">
                    <Setter Property="Margin" Value="5,5,0,5" />
                    <Setter Property="Padding" Value="0,2,0,0" />
                    <Setter Property="HorizontalAlignment" Value="Left" />
                    <Setter Property="FontSize" Value="14" />
                </Style>
                <Style TargetType="TextBox">
                    <Setter Property="Margin" Value="5,5,5,5" />
                    <Setter Property="Height" Value="22" />
                    <Setter Property="FontSize" Value="14" />
                    <Setter Property="AcceptsReturn" Value="True" />
                    <Setter Property="VerticalScrollBarVisibility" Value="Visible" />
                </Style>
                <Style TargetType="ComboBox">
                    <Setter Property="Height" Value="22" />
                    <Setter Property="Padding" Value="2,0,0,0" />
                    <Setter Property="Margin" Value="5" />
                    <Setter Property="FontSize" Value="14" />
                    <Setter Property="IsEditable" Value="True" />
                    <Setter Property="IsTextSearchEnabled" Value="True" />
                    <Setter Property="VerticalContentAlignment" Value="Center" />
                    <EventSetter Event="SelectionChanged" Handler="ComboBox_SelectionChanged"/>
                </Style>
                <Style TargetType="DatePicker">
                    <Setter Property="VerticalContentAlignment" Value="Center" />
                    <Setter Property="Height" Value="22" />
                    <Setter Property="Margin" Value="0,0,0,5" />
                    <Setter Property="Padding" Value="0,0,0,0" />
                    <Setter Property="FontSize" Value="14" />
                </Style>
                <Style TargetType="Border">
                    <Setter Property="BorderBrush" Value="Black" />
                    <Setter Property="Margin" Value="0" />
                </Style>
                <Style TargetType="Button">
                    <Setter Property="VerticalAlignment" Value="Bottom" />
                    <Setter Property="HorizontalAlignment" Value="Left" />
                    <Setter Property="Height" Value="18" />
                    <Setter Property="Width" Value="18" />
                </Style>
            </Grid.Resources>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="10*"></ColumnDefinition>
                <ColumnDefinition Width="15*"></ColumnDefinition>
                <ColumnDefinition Width="0*"></ColumnDefinition>
                <ColumnDefinition Width="12*"></ColumnDefinition>
                <ColumnDefinition Width="15*"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition></RowDefinition>
                <RowDefinition></RowDefinition>
                <RowDefinition></RowDefinition>
                <RowDefinition></RowDefinition>
                <RowDefinition></RowDefinition>
                <RowDefinition></RowDefinition>
                <RowDefinition></RowDefinition>
                <RowDefinition></RowDefinition>
                <RowDefinition></RowDefinition>
                <RowDefinition></RowDefinition>
                <RowDefinition></RowDefinition>
            </Grid.RowDefinitions>
            <Border BorderThickness="1" Grid.Row="0" Grid.Column="0" Grid.RowSpan="11" Grid.ColumnSpan="5" />
            <Border BorderThickness="0,0,1,0" Grid.Row="0" Grid.Column="0" Grid.RowSpan="8" Grid.ColumnSpan="3" />
            <Border BorderThickness="0,1,0,1" Grid.Row="1" Grid.Column="0" Grid.RowSpan="1" Grid.ColumnSpan="5" />
            <Border BorderThickness="0,1,0,1" Grid.Row="3" Grid.Column="0" Grid.RowSpan="1" Grid.ColumnSpan="5" />
            <Border BorderThickness="0,1,0,1" Grid.Row="5" Grid.Column="0" Grid.RowSpan="1" Grid.ColumnSpan="5" />
            <Border BorderThickness="0,1,0,1" Grid.Row="7" Grid.Column="0" Grid.RowSpan="1" Grid.ColumnSpan="5" />
            <Border BorderThickness="0,1,0,0" Grid.Row="9" Grid.Column="0" Grid.RowSpan="1" Grid.ColumnSpan="5" />

            <Label Name="ColorLabel" Content="Color:" Grid.Row="0" Grid.Column="0"></Label>
            <Label Name="AppearanceLabel" Content="Appearance:" Grid.Row="1" Grid.Column="0"></Label>
            <Label Name="ReactionLabel" Content="Reaction:" Grid.Row="2" Grid.Column="0"></Label>
            <Label Name="SPGravityLabel" Content="SP. Gravity:" Grid.Row="3" Grid.Column="0"></Label>
            <Label Name="AlbuminLabel" Content="Albumin:" Grid.Row="4" Grid.Column="0"></Label>
            <Label Name="SugarLabel" Content="Sugar:" Grid.Row="5" Grid.Column="0"></Label>
            <Label Name="PusCellsLabel" Content="Pus Cells:" Grid.Row="6" Grid.Column="0"></Label>
            <Label Name="RedCellsLabel" Content="Red Cells:" Grid.Row="7" Grid.Column="0"></Label>
            <Label Name="MucusThreadsLabel" Content="Mucus Threads:" Grid.Row="0" Grid.Column="3"></Label>
            <Label Name="EpithelialCellsLabel" Content="EpithelialCells:" Grid.Row="1" Grid.Column="3"></Label>
            <Label Name="AmorphousUratesPO4Label" Content="Amorphous Urates / PO4:" Grid.Row="2" Grid.Column="3"></Label>
            <Label Name="BacteriaLabel" Content="Bacteria:" Grid.Row="3" Grid.Column="3"></Label>
            <Label Name="CastsLabel" Content="Casts:" Grid.Row="4" Grid.Column="3"></Label>
            <Label Name="CrystalsLabel" Content="Crystals:" Grid.Row="5" Grid.Column="3"></Label>
            <Label Name="OthersLabel" Content="Others:" Grid.Row="8" Grid.Column="0"></Label>
            <Label Name="RemarksLabel" Content="Remarks:" Grid.Row="9" Grid.Column="0"></Label>

            <ComboBox Name="ColorComboBox" Grid.Row="0" Grid.Column="1" Tag="{Binding ColorField}" ItemsSource="{Binding Colors}" Text="{Binding Urinalysis.Color}"></ComboBox>
            <ComboBox Name="AppearanceComboBox" Grid.Row="1" Grid.Column="1" Tag="{Binding AppearanceField}" ItemsSource="{Binding Appearances}" Text="{Binding Urinalysis.Appearance}"></ComboBox>
            <ComboBox Name="ReactionComboBox" Grid.Row="2" Grid.Column="1" Tag="{Binding ReactionField}" ItemsSource="{Binding Reactions}" Text="{Binding Urinalysis.Reaction}"></ComboBox>
            <ComboBox Name="SPGravityComboBox" Grid.Row="3" Grid.Column="1" Tag="{Binding SPGravityField}" ItemsSource="{Binding SPGravities}" Text="{Binding Urinalysis.SPGravity}"></ComboBox>
            <ComboBox Name="AlbuminComboBox" Grid.Row="4" Grid.Column="1" Tag="{Binding AlbuminField}" ItemsSource="{Binding Albumins}" Text="{Binding Urinalysis.Albumin}"></ComboBox>
            <ComboBox Name="SugarComboBox" Grid.Row="5" Grid.Column="1" Tag="{Binding SugarField}" ItemsSource="{Binding Sugars}" Text="{Binding Urinalysis.Sugar}"></ComboBox>
            <ComboBox Name="PusCellsComboBox" Grid.Row="6" Grid.Column="1" Tag="{Binding PusCellsField}" ItemsSource="{Binding PusCells}" Text="{Binding Urinalysis.PusCells}"></ComboBox>
            <ComboBox Name="RedCellsComboBox" Grid.Row="7" Grid.Column="1" Tag="{Binding RedCellsField}" ItemsSource="{Binding RedCells}" Text="{Binding Urinalysis.RedCells}"></ComboBox>
            <ComboBox Name="MucusThreadsComboBox" Grid.Row="0" Grid.Column="4" Tag="{Binding MucusThreadField}" ItemsSource="{Binding MucusThreads}" Text="{Binding Urinalysis.MucusThreads}"></ComboBox>
            <ComboBox Name="EpithelialCellsComboBox" Grid.Row="1" Grid.Column="4" Tag="{Binding EpithelialCellsField}" ItemsSource="{Binding EpithelialCells}" Text="{Binding Urinalysis.EpithelialCells}"></ComboBox>
            <ComboBox Name="AmorphousUratesPO4ComboBox" Grid.Row="2" Grid.Column="4" Tag="{Binding AmorphousUratesPO4Field}" ItemsSource="{Binding AmorphousUratesPO4s}" Text="{Binding Urinalysis.AmorphousUratesPO4}"></ComboBox>
            <ComboBox Name="BacteriaComboBox" Grid.Row="3" Grid.Column="4" Tag="{Binding BacteriaField}" ItemsSource="{Binding Bacterias}" Text="{Binding Urinalysis.Bacteria}"></ComboBox>
            <ComboBox Name="CastsComboBox" Grid.Row="4" Grid.Column="4" Tag="{Binding CastsField}" ItemsSource="{Binding Casts}" Text="{Binding Urinalysis.Casts}"></ComboBox>
            <ComboBox Name="CrystalsComboBox" Grid.Row="5" Grid.Column="4" Tag="{Binding CrystalsField}" ItemsSource="{Binding Crystalss}" Text="{Binding Urinalysis.Crystals}"></ComboBox>
            <TextBox Name="OthersTextBox" Grid.Row="8" Grid.Column="1" Grid.ColumnSpan="4" Text="{Binding Urinalysis.Others}"
                     Height="50" MouseDoubleClick="OthersTextBox_MouseDoubleClick"></TextBox>
            <Button Name="SelectOthersButton" Grid.Row="8" Grid.Column="1" Margin="7" Click="SelectOthersButton_Click">
                <StackPanel>
                    <Image Source="/Images/16x16/edit.png" />
                </StackPanel>
            </Button>
            <TextBox Name="RemarksTextBox" Grid.Row="10" Grid.Column="0" Grid.ColumnSpan="5" Text="{Binding Urinalysis.Remarks}"
                     Height="40" Margin="5,0,5,5" MouseDoubleClick="RemarksTextBox_MouseDoubleClick"></TextBox>
            <Button Name="SelectRemarksButton" Grid.Row="10" Grid.Column="0" Margin="7" Click="SelectRemarksButton_Click">
                <StackPanel>
                    <Image Source="/Images/16x16/edit.png" />
                </StackPanel>
            </Button>
        </Grid>
        <Grid Margin="10,0,10,10" VerticalAlignment="Top">
            <Grid.Resources>
                <Style TargetType="Label">
                    <Setter Property="Margin" Value="5,0,0,5" />
                    <Setter Property="Padding" Value="0,2,0,0" />
                    <Setter Property="HorizontalAlignment" Value="Center" />
                    <Setter Property="FontSize" Value="14" />
                </Style>
                <Style TargetType="ComboBox">
                    <Setter Property="VerticalContentAlignment" Value="Center" />
                    <Setter Property="Height" Value="24" />
                    <Setter Property="Margin" Value="10,10,10,0" />
                    <Setter Property="Padding" Value="5,0,0,0" />
                    <Setter Property="BorderThickness" Value="1" />
                    <Setter Property="FontSize" Value="14" />
                </Style>
            </Grid.Resources>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="10*"></ColumnDefinition>
                <ColumnDefinition Width="10*"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition></RowDefinition>
                <RowDefinition></RowDefinition>
                <RowDefinition></RowDefinition>
                <RowDefinition></RowDefinition>
            </Grid.RowDefinitions>
            <ComboBox Name="MedicalTechnologistComboBox" Grid.Row="0" Grid.Column="0" IsEditable="True" IsTextSearchEnabled="True"
                      ItemsSource="{Binding MedicalTechnologists}" SelectedValue="{Binding Urinalysis.MedicalTechnologist}" SelectionChanged="MedicalTechnologistComboBox_SelectionChanged"></ComboBox>
            <Label Name="MedicalTechnologistLabel" Content="Medical Technologist" Grid.Row="1" Grid.Column="0"></Label>
            <ComboBox Name="PathologistComboBox" Grid.Row="0" Grid.Column="1" IsEditable="True" IsTextSearchEnabled="True"
                      ItemsSource="{Binding Pathologists}" SelectedValue="{Binding Urinalysis.Pathologist}" SelectionChanged="PathologistComboBox_SelectionChanged"></ComboBox>
            <Label Name="PathologistLabel" Content="Pathologist" Grid.Row="1" Grid.Column="1"></Label>
        </Grid>
    </StackPanel>
</Window>
